rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null &&
             (request.auth.token.email == "contatojuniorla@gmail.com" ||
              request.auth.token.email == "CanalPapeldeTrouxa@gmail.com") &&
             request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidLead(data) {
      return data.keys().hasAll([
        'fullName', 'phone', 'email', 'city', 'eventDate', 'eventType',
        'guestCount', 'budget', 'description', 'hasLocation', 'style',
        'referredBy', 'whatsappConsent', 'status', 'createdAt'
      ]) && data.keys().size() == 15
      && data.fullName is string && data.fullName.size() <= 200
      && data.phone is string && data.phone.size() <= 100
      && data.email is string && data.email.size() <= 200
      && data.city is string && data.city.size() <= 100
      && data.eventDate is string && data.eventDate.size() <= 100
      && data.eventType is string && data.eventType.size() <= 100
      && data.guestCount is string && data.guestCount.size() <= 100
      && data.budget is string && data.budget.size() <= 100
      && data.description is string && data.description.size() <= 5000
      && data.hasLocation is string && data.hasLocation.size() <= 100
      && data.style is string && data.style.size() <= 100
      && data.referredBy is string && data.referredBy.size() <= 100
      && data.whatsappConsent is bool
      && data.status is string && data.status in ['Novos', 'Em análise', 'Interessantes', 'Sem perfil', 'Respondidos']
      && data.createdAt is timestamp;
    }

    match /leads/{leadId} {
      allow create: if isValidId(leadId) 
                    && isValidLead(incoming())
                    && incoming().status == 'Novos'
                    && incoming().createdAt == request.time;
      
      allow read: if isAdmin();
      
      allow update: if isAdmin() 
                    && isValidId(leadId) 
                    && isValidLead(incoming())
                    && incoming().createdAt == existing().createdAt;
                    
      allow delete: if isAdmin();
    }
  }
}
